# Postgres connection string used by Prisma and by the app.
# Port 5433 matches docker-compose.yml's host mapping for the db service
# (5433 avoids clashing with a native Postgres already on 5432, if any).
DATABASE_URL=postgresql://dominia:dominia@localhost:5433/dominia

# docker-compose Postgres credentials (db service)
POSTGRES_USER=dominia
POSTGRES_PASSWORD=dominia
POSTGRES_DB=dominia
