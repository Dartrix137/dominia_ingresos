// Prisma schema for DOMINIA 1.0 ticketing app

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Attendee {
  id            String     @id @default(cuid())
  uuid          String     @unique @default(uuid())
  fullName      String
  cedula        String     @unique
  locality      String     // "VIP" | "General Baja" | "General Alta"
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  checkIns      CheckIn[]
}

model CheckIn {
  id           String   @id @default(cuid())
  attendeeId   String
  attendee     Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  checkedAt    DateTime @default(now())
  revertedAt   DateTime?
  // true while the check-in is in effect, null once reverted.
  // SQLite/Postgres unique indexes treat NULL as distinct, so this
  // constraint allows unlimited reverted history while guaranteeing
  // at most one active check-in per attendee at the database level —
  // this is what makes concurrent check-in requests safe.
  active       Boolean? @default(true)
  notes        String?

  @@unique([attendeeId, active])
  @@index([checkedAt])
}
